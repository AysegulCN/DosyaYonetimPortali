@{
    var storageInfo = DosyaYonetimPortali.MVC.Controllers.DriveController.GetStorageInfo();
    long currentQuotaMB = DosyaYonetimPortali.MVC.Controllers.DriveController.UserTotalQuotaMB;
    int currentQuotaGB = (int)(currentQuotaMB / 1024);
    
    string userName = DosyaYonetimPortali.MVC.Controllers.DriveController.CurrentFullName ?? "Kullanıcı";
    string userEmail = DosyaYonetimPortali.MVC.Controllers.DriveController.CurrentEmail ?? "kullanici@coredrive.com";
    string userPhone = DosyaYonetimPortali.MVC.Controllers.DriveController.CurrentPhone ?? "";
    string userAvatar = DosyaYonetimPortali.MVC.Controllers.DriveController.CurrentAvatarBase64 ?? "";
    
    string initial = !string.IsNullOrEmpty(userName) ? userName.Substring(0,1).ToUpper() : "K";
    bool isAdmin = User.IsInRole("Admin") || userName?.ToLower() == "sistem" || userName?.ToLower() == "patron";
    bool isAdminPage = ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin";
}
<!DOCTYPE html>
<html lang="tr" data-theme="light">
<head>
    <meta charset="utf-8">
    <title>CoreDrive</title>
    <link href="~/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="~/css/sb-admin-2.min.css" rel="stylesheet">
    <style>
        :root {
            --bg-main: #ffffff; --bg-secondary: #f8f9fa; --bg-hover: #f1f3f4;
            --text-main: #202124; --text-muted: #5f6368; --border-color: #dadce0;
            --active-bg: #e8f0fe; --active-text: #1967d2; --input-bg: #f1f3f4;
            --card-bg: #ffffff; --table-hover: #f5f5f5;
        }
        [data-theme="dark"] {
            --bg-main: #202124; --bg-secondary: #292a2d; --bg-hover: #3c4043;
            --text-main: #e8eaed; --text-muted: #9aa0a6; --border-color: #5f6368;
            --active-bg: #3c4043; --active-text: #8ab4f8; --input-bg: #303134;
            --card-bg: #2d2e30; --table-hover: #303134;
        }
        body { background-color: var(--bg-main) !important; color: var(--text-main) !important; overflow: hidden; font-family: 'Segoe UI', sans-serif; transition: background-color 0.3s, color 0.3s; }
        .text-dark { color: var(--text-main) !important; }
        .text-muted { color: var(--text-muted) !important; }
        .bg-light { background-color: var(--bg-hover) !important; }
        .border, .border-bottom, .border-top { border-color: var(--border-color) !important; }
        .drive-navbar { background-color: var(--bg-main); border-bottom: 1px solid var(--border-color); padding: 8px 16px; height: 64px; }
        .drive-sidebar { width: 256px; height: calc(100vh - 64px); float: left; background-color: var(--bg-main); padding-top: 15px; border-right: 1px solid var(--border-color); }
        .drive-main { margin-left: 256px; height: calc(100vh - 64px); padding: 0 30px; overflow-y: auto; background-color: var(--bg-main); }
        .nav-link-drive { display: flex; align-items: center; padding: 12px 24px; color: var(--text-main); border-radius: 0 24px 24px 0; font-weight: 500; text-decoration: none; margin-bottom: 4px; }
        .nav-link-drive:hover { background-color: var(--bg-hover); color: var(--text-main); text-decoration: none; }
        .nav-link-drive.active { background-color: var(--active-bg); color: var(--active-text); }
        .nav-link-drive i { font-size: 18px; margin-right: 18px; color: var(--text-muted); width: 24px; text-align: center; }
        .nav-link-drive.active i { color: var(--active-text); }
        .search-bar { background-color: var(--input-bg); border-radius: 8px; padding: 8px 16px; width: 100%; max-width: 720px; display: flex; align-items: center; border: 1px solid transparent; }
        .search-bar input { border: none; background: transparent; width: 100%; outline: none; margin-left: 10px; font-size: 16px; color: var(--text-main); }
        .storage-area { padding: 12px 24px; margin-top: 15px; cursor: pointer; border-radius: 0 24px 24px 0; margin-right: 12px; }
        .storage-area:hover { background-color: var(--bg-hover); }
        .btn-google-new { background-color: var(--card-bg); color: var(--text-main); border-radius: 24px; padding: 8px 24px 8px 12px; box-shadow: 0 1px 2px 0 rgba(0,0,0,0.2); font-weight: 500; font-size: 14px; border: 1px solid var(--border-color); display: inline-flex; align-items: center; gap: 8px; cursor: pointer; }
        .folder-card { border: 1px solid var(--border-color); background-color: var(--card-bg); border-radius: 8px; padding: 12px 16px; display: flex; align-items: center; cursor: pointer; color: var(--text-main); font-weight: 500; font-size: 14px; text-decoration: none !important; }
        .file-table { width: 100%; border-collapse: collapse; }
        .file-table th { color: var(--text-muted); font-weight: 500; font-size: 13px; text-align: left; padding: 12px 15px; border-bottom: 1px solid var(--border-color); }
        .file-table td { padding: 12px 15px; border-bottom: 1px solid var(--border-color); color: var(--text-main); font-size: 13px; font-weight: 500; }
        .plan-card { border: 2px solid var(--border-color); border-radius: 16px; padding: 30px 20px; text-align: center; background: var(--card-bg); position: relative; overflow: hidden; }
        .plan-card.active-plan { border-color: #1a73e8; background: var(--bg-hover); }
        .btn-theme-toggle { background: none; border: none; color: var(--text-muted); font-size: 20px; width: 40px; height: 40px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center;}
        .avatar-circle { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: bold; font-size: 16px; background-color: #1a73e8; border: 1px solid var(--border-color); }
        .avatar-circle-lg { width: 70px; height: 70px; font-size: 32px; margin: 0 auto 10px auto; }
        .nav-pills .nav-link { color: var(--text-main); border-radius: 8px; font-weight: 500; margin-bottom: 5px; }
        .nav-pills .nav-link.active { background-color: var(--active-bg); color: var(--active-text); }
        .nav-pills .nav-link:hover:not(.active) { background-color: var(--bg-hover); }
    </style>
</head>
<body>
    <header class="drive-navbar d-flex align-items-center justify-content-between">
        <div style="width: 240px;"><a href="/Drive/Dashboard" class="text-decoration-none text-dark font-weight-bold" style="font-size: 22px;"><i class="fas fa-cloud text-primary mr-2" style="font-size: 28px;"></i>CoreDrive</a></div>
        <div class="search-bar mx-4 d-none d-md-flex"><i class="fas fa-search text-muted"></i><input type="text" placeholder="Drive'da arayın"></div>
        <div class="d-flex align-items-center">
            @if (isAdminPage) { <a href="/Drive/Dashboard" class="btn btn-outline-primary btn-sm mr-3 font-weight-bold" style="border-radius: 20px;"><i class="fas fa-external-link-alt mr-1"></i> Siteye Göz At</a> }
            <button class="btn-theme-toggle mr-1" data-toggle="modal" data-target="#settingsModal" title="Ayarlar"><i class="fas fa-cog"></i></button>
            <button id="themeToggleBtn" class="btn-theme-toggle mr-3" title="Temayı Değiştir"><i class="fas fa-moon"></i></button>
            <div class="dropdown">
                <a href="#" class="d-flex align-items-center text-decoration-none" data-toggle="dropdown">
                    @if(string.IsNullOrEmpty(userAvatar)) { <div class="avatar-circle shadow-sm">@initial</div> } else { <img src="@userAvatar" class="rounded-circle border shadow-sm" style="width:36px; height:36px; object-fit:cover;"> }
                </a>
                <div class="dropdown-menu dropdown-menu-right shadow-sm mt-2" style="border-radius: 8px; min-width: 240px;">
                    <div class="px-3 py-3 text-center border-bottom">
                        @if(string.IsNullOrEmpty(userAvatar)) { <div class="avatar-circle avatar-circle-lg shadow-sm">@initial</div> } else { <img src="@userAvatar" class="rounded-circle border shadow-sm mb-2" style="width:70px; height:70px; object-fit:cover;"> }
                        <div class="font-weight-bold text-dark">@userName</div><div class="small text-muted">@userEmail</div>
                    </div>
                    @if(isAdmin) { <a class="dropdown-item py-2 mt-2 font-weight-bold text-primary" href="/Admin/Dashboard"><i class="fas fa-user-shield mr-3"></i> Admin Paneli</a> }
                    <a class="dropdown-item py-2 @(isAdmin ? "" : "mt-2")" href="#" data-toggle="modal" data-target="#profileModal"><i class="fas fa-user-edit mr-3 text-muted"></i> Profilimi Düzenle</a>
                    <a class="dropdown-item py-2" href="#" data-toggle="modal" data-target="#settingsModal"><i class="fas fa-sliders-h mr-3 text-muted"></i> Ayarlar</a>
                    <div class="dropdown-divider my-2"></div>
                    <a class="dropdown-item py-2 text-danger" href="/Auth/Logout"><i class="fas fa-sign-out-alt mr-3"></i> Çıkış Yap</a>
                </div>
            </div>
        </div>
    </header>
    <nav class="drive-sidebar">
        <a href="/Drive/Dashboard" class="nav-link-drive @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")"><i class="fas fa-hdd"></i> Drive'ım</a>
        <a href="/Drive/Shared" class="nav-link-drive @(ViewContext.RouteData.Values["Action"]?.ToString() == "Shared" ? "active" : "")"><i class="fas fa-user-friends"></i> Benimle Paylaşılanlar</a>
        <a href="/Drive/Trash" class="nav-link-drive @(ViewContext.RouteData.Values["Action"]?.ToString() == "Trash" ? "active" : "")"><i class="fas fa-trash"></i> Çöp Kutusu</a>
        <hr class="mx-3 my-3 border-bottom">
        <div class="storage-area" data-toggle="modal" data-target="#settingsModal">
            <div class="text-muted font-weight-bold mb-2" style="font-size: 13px;"><i class="fas fa-cloud mr-2"></i> Depolama Alanı</div>
            <div class="progress mb-2" style="height: 6px; border-radius: 3px; background-color: var(--border-color);"><div class="progress-bar @(storageInfo.Percent > 80 ? "bg-danger" : "bg-primary")" style="width: @storageInfo.Percent%;"></div></div>
            <div class="text-muted" style="font-size: 12px;">@storageInfo.Total'ın @storageInfo.Used'ı kullanılıyor</div>
        </div>
    </nav>
    <main class="drive-main">
        @if (TempData["SuccessMessage"] != null) { <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mt-4 mb-0" style="border-radius: 8px;"><i class="fas fa-check-circle mr-3"></i>@TempData["SuccessMessage"]<button type="button" class="close text-dark" data-dismiss="alert"><span>&times;</span></button></div> }
        @RenderBody()
    </main>
    <div class="modal fade" id="settingsModal" tabindex="-1"><div class="modal-dialog modal-lg modal-dialog-centered"><div class="modal-content" style="border-radius: 12px; border: none; overflow: hidden;"><div class="modal-header border-bottom px-4 pt-4 pb-3"><h4 class="modal-title font-weight-bold text-dark"><i class="fas fa-cog text-muted mr-2"></i> Ayarlar</h4><button type="button" class="close text-dark" data-dismiss="modal"><span>&times;</span></button></div><div class="modal-body p-0 d-flex" style="min-height: 400px;"><div class="border-right" style="width: 200px; background: var(--bg-secondary); padding: 20px 10px;"><div class="nav flex-column nav-pills" role="tablist"><a class="nav-link active" data-toggle="pill" href="#set-genel"><i class="fas fa-sliders-h mr-2"></i> Genel</a><a class="nav-link" data-toggle="pill" href="#set-plan"><i class="fas fa-hdd mr-2"></i> Plan</a></div></div><div class="tab-content p-4 flex-grow-1"><div class="tab-pane fade show active" id="set-genel"><h5 class="mb-3">Genel Ayarlar</h5><div class="d-flex justify-content-between align-items-center pb-3 border-bottom"><div><h6>Arayüz Dili</h6><small class="text-muted">Sistem dilini değiştirin</small></div><select class="form-control w-auto"><option>Türkçe</option><option>English</option></select></div></div><div class="tab-pane fade" id="set-plan"><h5 class="mb-3">Depolama Bilgileri</h5><div class="p-4 mb-3 text-center bg-light rounded border"><i class="fas fa-cloud text-primary mb-2" style="font-size: 24px;"></i><h4>@currentQuotaGB GB Plan</h4><p class="m-0">Kullanılan: @storageInfo.Used / @storageInfo.Total</p></div><button class="btn btn-primary w-100" data-dismiss="modal" data-toggle="modal" data-target="#upgradeModal">Planı Yükselt</button></div></div></div></div></div></div>
    <div class="modal fade" id="profileModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><div class="modal-content" style="border-radius: 12px;"><div class="modal-header border-0 pb-0 pt-4 px-4"><h5 class="modal-title font-weight-bold text-dark">Profil Bilgileri</h5><button type="button" class="close text-dark" data-dismiss="modal"><span>&times;</span></button></div><form asp-action="UpdateProfile" asp-controller="Drive" method="post" enctype="multipart/form-data"><input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.Path" /><div class="modal-body px-4 py-3"><div class="text-center mb-4"><div class="position-relative d-inline-block">@if(string.IsNullOrEmpty(userAvatar)) { <div class="avatar-circle shadow-sm" style="width:90px; height:90px; font-size:40px;">@initial</div> } else { <img src="@userAvatar" class="rounded-circle border shadow-sm" style="width:90px; height:90px; object-fit:cover;"> } <label for="avatarUpload" class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center position-absolute m-0" style="bottom: 0; right: 0; width: 32px; height: 32px; cursor: pointer; border: 3px solid var(--card-bg);"><i class="fas fa-camera" style="font-size: 13px;"></i></label><input type="file" id="avatarUpload" name="avatarFile" accept="image/*" style="display: none;"></div></div><div class="row"><div class="col-md-6 mb-3"><label class="small font-weight-bold text-muted">Ad Soyad</label><input type="text" name="fullName" class="form-control shadow-none" value="@userName"></div><div class="col-md-6 mb-3"><label class="small font-weight-bold text-muted">E-Posta</label><input type="email" name="email" class="form-control shadow-none" value="@userEmail"></div></div><div class="form-group mb-4"><label class="small font-weight-bold text-muted">Telefon</label><input type="tel" name="phone" class="form-control shadow-none" value="@userPhone"></div><hr><div class="form-group mb-2"><label class="small font-weight-bold text-danger"><i class="fas fa-shield-alt mr-1"></i> Mevcut Şifre</label><div class="input-group"><input type="password" name="currentPassword" id="currentPassword" class="form-control border-danger" required><div class="input-group-append"><button class="btn btn-outline-secondary toggle-password" type="button" data-target="currentPassword"><i class="fas fa-eye"></i></button></div></div></div></div><div class="modal-footer border-0 px-4 pb-4 pt-2 bg-light"><button type="button" class="btn btn-light" data-dismiss="modal">İptal</button><button type="submit" class="btn btn-primary px-4" style="border-radius: 20px;">Kaydet</button></div></form></div></div></div>
    <div class="modal fade" id="upgradeModal" tabindex="-1"><div class="modal-dialog modal-xl modal-dialog-centered"><div class="modal-content" style="border-radius: 16px;"><div class="modal-header border-0 pt-4 px-5"><h4 class="modal-title font-weight-bold text-dark">Depolama Alanını Yükselt</h4><button type="button" class="close" data-dismiss="modal" style="font-size: 28px;"><span>&times;</span></button></div><div class="modal-body px-5 py-4"><p class="text-muted mb-4">İhtiyacınıza uygun planı seçin. Yükseltme talebiniz IT departmanı tarafından onaylanacaktır.</p><div class="row">@foreach (var plan in new[] { (15, "Standart", "hdd"), (50, "Profesyonel", "cloud"), (250, "Kurumsal", "server") }) { <div class="col-md-4 mb-3"><div class="plan-card h-100 @(currentQuotaGB == plan.Item1 ? "active-plan" : "")">@if(currentQuotaGB == plan.Item1) { <div class="plan-badge">MEVCUT</div> } <div class="plan-icon" style="width:64px;height:64px;margin:0 auto 15px;display:flex;align-items:center;justify-content:center;background:var(--bg-hover);border-radius:50%;font-size:24px;"><i class="fas fa-@plan.Item3"></i></div><h5 class="font-weight-bold">@plan.Item2</h5><h2 class="text-primary my-3 font-weight-bold">@plan.Item1 GB</h2>@if(currentQuotaGB == plan.Item1) { <button class="btn btn-primary w-100 disabled">Şu An Kullanımda</button> } else { <form asp-action="RequestQuotaUpgrade" asp-controller="Drive" method="post"><input type="hidden" name="requestedQuotaGB" value="@plan.Item1"/><input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.Path" /><button type="submit" class="btn btn-outline-primary w-100">Talebi Gönder</button></form> } </div></div> } </div></div></div></div></div>
    <script src="~/vendor/jquery/jquery.min.js"></script><script src="~/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const html = document.documentElement;
            const themeBtn = document.getElementById('themeToggleBtn');
            const themeIcon = themeBtn.querySelector('i');
            const currentTheme = localStorage.getItem('theme') || 'light';
            
            const updateIcon = (theme) => {
                if(theme === 'dark') { themeIcon.className = 'fas fa-sun'; themeIcon.style.color = '#fbbc05'; } 
                else { themeIcon.className = 'fas fa-moon'; themeIcon.style.color = 'var(--text-muted)'; }
            };

            html.setAttribute('data-theme', currentTheme);
            updateIcon(currentTheme);

            themeBtn.addEventListener('click', () => {
                const newTheme = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
                html.setAttribute('data-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                updateIcon(newTheme);
            });

            document.querySelectorAll('.toggle-password').forEach(btn => {
                btn.addEventListener('click', function() {
                    const input = document.getElementById(this.getAttribute('data-target'));
                    const icon = this.querySelector('i');
                    input.type = input.type === 'password' ? 'text' : 'password';
                    icon.className = input.type === 'password' ? 'fas fa-eye' : 'fas fa-eye-slash';
                });
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>