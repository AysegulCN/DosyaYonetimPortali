<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>CoreDrive - Dosyalarım</title>
    
    <link href="~/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="~/css/sb-admin-2.min.css" rel="stylesheet">
    <style>
        body { background-color: #fff; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; overflow: hidden; }
        
        .drive-navbar { background-color: #fff; border-bottom: 1px solid #dadce0; padding: 8px 16px; height: 64px; }
        .drive-brand { font-size: 22px; color: #5f6368; font-weight: 500; text-decoration: none; display: flex; align-items: center; }
        
        .drive-sidebar { width: 256px; height: calc(100vh - 64px); float: left; padding: 16px 0; background-color: #fff; }
        .drive-main { margin-left: 256px; height: calc(100vh - 64px); padding: 20px 30px; overflow-y: auto; background-color: #fff; }
        
        .nav-item-drive { padding: 0 12px; margin-bottom: 4px; }
        .nav-link-drive { display: flex; align-items: center; padding: 10px 24px; color: #3c4043; text-decoration: none; border-radius: 0 24px 24px 0; font-weight: 500; font-size: 14px; }
        .nav-link-drive:hover { background-color: #f1f3f4; text-decoration: none; color: #3c4043; }
        .nav-link-drive.active { background-color: #e8f0fe; color: #1967d2; }
        .nav-link-drive.active i { color: #1967d2; }
        .nav-link-drive i { font-size: 18px; margin-right: 18px; color: #5f6368; width: 24px; text-align: center; }
        
        .search-bar { background-color: #f1f3f4; border-radius: 8px; padding: 8px 16px; width: 100%; max-width: 720px; display: flex; align-items: center; }
        .search-bar input { border: none; background: transparent; width: 100%; outline: none; margin-left: 10px; font-size: 16px; color: #3c4043; }
    </style>
</head>
<body>
    
    <header class="drive-navbar d-flex align-items-center justify-content-between sticky-top">
        <div class="d-flex align-items-center" style="width: 240px;">
            <a href="/Drive/Dashboard" class="drive-brand">
                <i class="fas fa-cloud text-primary mr-2" style="font-size: 28px;"></i>
                <span class="ml-1">CoreDrive</span>
            </a>
        </div>
        
        <div class="search-bar mx-4 d-none d-md-flex">
            <i class="fas fa-search text-muted"></i>
            <input type="text" placeholder="Drive'da dosya veya klasör arayın">
        </div>
        
        <div class="d-flex align-items-center">
            <div class="dropdown">
                <a href="#" class="d-flex align-items-center text-decoration-none" data-toggle="dropdown">
                    <img src="~/img/undraw_profile.svg" class="rounded-circle border" width="36" height="36">
                </a>
                <div class="dropdown-menu dropdown-menu-right shadow-sm border-0 mt-2" style="border-radius: 8px;">
                    <span class="dropdown-item-text text-muted small pb-2 border-bottom">@User.Identity.Name</span>
                    <a class="dropdown-item py-2 text-danger mt-1" href="/Auth/Logout">
                        <i class="fas fa-sign-out-alt mr-2"></i> Çıkış Yap
                    </a>
                </div>
            </div>
        </div>
    </header>

    <div>
        <nav class="drive-sidebar d-none d-md-block">
            <div class="nav-item-drive">
                <a href="/Drive/Dashboard" class="nav-link-drive @(ViewContext.RouteData.Values["Action"].ToString() == "Dashboard" ? "active" : "")">
                    <i class="fas fa-hdd"></i> Drive'ım
                </a>
            </div>
            <div class="nav-item-drive">
                <a href="/Drive/Shared" class="nav-link-drive @(ViewContext.RouteData.Values["Action"].ToString() == "Shared" ? "active" : "")">
                    <i class="fas fa-user-friends"></i> Benimle Paylaşılanlar
                </a>
            </div>
            <div class="nav-item-drive">
                <a href="/Drive/Trash" class="nav-link-drive @(ViewContext.RouteData.Values["Action"].ToString() == "Trash" ? "active" : "")">
                    <i class="fas fa-trash"></i> Çöp Kutusu
                </a>
            </div>
            
            <hr class="mx-3 my-3" style="border-color: #dadce0;">
            
            <div class="px-4 mt-3">
                <div class="d-flex align-items-center text-muted mb-2" style="font-size: 13px;">
                    <i class="fas fa-cloud mr-2"></i> Depolama Alanı
                </div>
                <div class="progress mb-2" style="height: 6px; border-radius: 3px;">
                    <div class="progress-bar bg-primary" role="progressbar" style="width: 45%;"></div>
                </div>
                <div class="text-muted" style="font-size: 13px;">15 GB'ın 6.7 GB'ı kullanılıyor</div>
            </div>
        </nav>

        <main class="drive-main">
            @RenderBody()
        </main>
    </div>

    <script src="~/vendor/jquery/jquery.min.js"></script>
    <script src="~/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>