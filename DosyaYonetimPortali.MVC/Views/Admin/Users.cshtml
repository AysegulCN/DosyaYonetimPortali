@model List<DosyaYonetimPortali.MVC.Models.UserViewModel>
@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 fw-bold">Sistem Kullanıcıları</h1>
    <button class="btn btn-primary shadow-sm" style="border-radius: 10px;">
        <i class="fas fa-user-plus fa-sm text-white-50"></i> Yeni Kullanıcı
    </button>
</div>

<!-- Tablo Kartı -->
<div class="card shadow mb-4" style="border-radius: 15px; border: none;">
    <div class="card-header py-3 bg-white" style="border-bottom: 1px solid #e3e6f0; border-top-left-radius: 15px; border-top-right-radius: 15px;">
        <h6 class="m-0 font-weight-bold text-primary">Kayıtlı Tüm Hesaplar</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th>Kullanıcı Bilgisi</th>
                        <th>E-posta</th>
                        <th>Rol</th>
                        <th>Depolama Alanı</th>
                        <th>Durum</th>
                        <th class="text-center">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Admin Satırı -->
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="https://ui-avatars.com/api/?name=Sistem+Yonetici&background=4e73df&color=fff" class="rounded-circle me-3" width="40">
                                <div>
                                    <div class="fw-bold text-dark">Sistem Yöneticisi</div>
                                    <div class="small text-muted">ID: #0001</div>
                                </div>
                            </div>
                        </td>
                        <td>patron@coredrive.com</td>
                        <td><span class="badge bg-danger rounded-pill px-3 py-2">Admin</span></td>
                        <td><i class="fas fa-hdd text-muted me-1"></i> 1.2 GB</td>
                        <td><span class="text-success"><i class="fas fa-circle fa-xs me-1"></i> Aktif</span></td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-primary shadow-sm"><i class="fas fa-edit"></i></button>
                        </td>
                    </tr>
                    
                    <!-- Normal User Satırı -->
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="https://ui-avatars.com/api/?name=Aysegul+Yilmaz&background=1cc88a&color=fff" class="rounded-circle me-3" width="40">
                                <div>
                                    <div class="fw-bold text-dark">Ayşegül Yılmaz</div>
                                    <div class="small text-muted">ID: #0045</div>
                                </div>
                            </div>
                        </td>
                        <td>aysegul@coredrive.com</td>
                        <td><span class="badge bg-primary rounded-pill px-3 py-2">User</span></td>
                        <td><i class="fas fa-hdd text-muted me-1"></i> 14.5 GB</td>
                        <td><span class="text-success"><i class="fas fa-circle fa-xs me-1"></i> Aktif</span></td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-primary shadow-sm me-1"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-outline-danger shadow-sm"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<tbody>
    @if (Model != null && Model.Count > 0)
    {
        foreach (var user in Model)
        {
            <tr>
                <td>
                    <div class="d-flex align-items-center">
                        <img src="https://ui-avatars.com/api/?name=@user.FullName&background=random&color=fff" class="rounded-circle me-3" width="40">
                        <div>
                            <div class="fw-bold text-dark">@user.FullName</div>
                            <div class="small text-muted">ID: @user.Id.Substring(0, 8)...</div>
                        </div>
                    </div>
                </td>
                <td>@user.Email</td>
                <td>
                    @if (user.Role == "Admin")
                    {
                        <span class="badge bg-danger rounded-pill px-3 py-2">Admin</span>
                    }
                    else
                    {
                        <span class="badge bg-primary rounded-pill px-3 py-2">User</span>
                    }
                </td>
                <td><i class="fas fa-hdd text-muted me-1"></i> Hesaplanan...</td>
                <td><span class="text-success"><i class="fas fa-circle fa-xs me-1"></i> Aktif</span></td>
                
                <!-- İŞTE CANLANDIRDIĞIMIZ BUTONLARIN OLDUĞU KISIM BURASI -->
                <td class="text-center">
                    <!-- Yetki Değiştirme Butonu (Sarı Kalkan) -->
                    <form asp-action="ToggleRole" asp-controller="Admin" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@user.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-warning shadow-sm me-1" title="Yetkiyi Değiştir" onclick="return confirm('Kullanıcının Admin/User yetkisini değiştirmek üzeresiniz. Emin misiniz?');">
                            <i class="fas fa-user-shield"></i>
                        </button>
                    </form>

                    @if (user.Role != "Admin")
                    {
                        <!-- Silme Butonu Sadece Normal Kullanıcılarda Çıkar (Kırmızı Çöp Kutusu) -->
                        <form asp-action="DeleteUser" asp-controller="Admin" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm" title="Kullanıcıyı Sil" onclick="return confirm('Bu kullanıcıyı sistemden tamamen silmek istediğinize emin misiniz? Bu işlem geri alınamaz!');">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    }
                </td>
            </tr>
        }
    }
    else
    {
        <tr>
            <td colspan="6" class="text-center py-4">Henüz kayıtlı kullanıcı bulunamadı.</td>
        </tr>
    }
</tbody>
