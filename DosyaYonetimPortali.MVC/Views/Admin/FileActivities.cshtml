@model List<DosyaYonetimPortali.MVC.Models.FileActivityViewModel>
@{
    ViewData["Title"] = "Dosya Hareketleri";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .btn-animated:active { transform: scale(0.95); }
    .modern-table tbody tr { transition: all 0.25s ease-in-out; border-bottom: 1px solid #f1f3f5; }
    .modern-table tbody tr:hover { background-color: #f8f9fc; }
    .modern-table td { border-top: none !important; padding: 1.25rem 1rem !important; vertical-align: middle; font-weight: 500; color: #5a5c69; }
    .modern-table th { font-weight: 700; color: #858796; text-transform: uppercase; letter-spacing: 1px; font-size: 0.85rem; padding: 1.5rem 1rem; }
    
    .action-badge {
        font-weight: 600;
        letter-spacing: 0.5px;
        padding: 6px 14px !important;
        border-radius: 20px;
        font-size: 0.8rem;
    }
    .badge-download { background-color: #36b9cc; color: white; }
    .badge-upload { background-color: #1cc88a; color: white; }
    .badge-delete { background-color: #e74a3b; color: white; }
    .badge-share { background-color: #f6c23e; color: white; }

    .search-box {
        position: relative;
        display: flex;
        width: 300px;
    }
    .search-input {
        border-radius: 10px 0 0 10px;
        border: 1px solid #d1d3e2;
        padding: 0.6rem 1rem;
        box-shadow: none;
    }
    .search-input:focus {
        border-color: #4e73df;
        outline: none;
    }
    .search-btn {
        border-radius: 0 10px 10px 0;
        padding: 0.6rem 1.2rem;
    }

    .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none !important;
    }
</style>

<div class="d-sm-flex align-items-center justify-content-between mb-4 mt-2">
    <h1 class="h3 mb-0 text-gray-800 fw-bold">Sistem Dosya Hareketleri</h1>
    
    <div class="d-flex align-items-center gap-3">
        <div class="search-box shadow-sm">
            <input type="text" id="activitySearch" class="form-control search-input" placeholder="Dosya veya eylem ara..." autocomplete="off">
            <button class="btn btn-primary search-btn" type="button" style="cursor: default;">
                <i class="fas fa-search fa-sm"></i>
            </button>
        </div>
        
        <form asp-action="DownloadFileActivitiesCsv" asp-controller="Admin" method="post" class="m-0">
            <button type="submit" class="btn btn-primary shadow-sm btn-animated" style="border-radius: 10px; padding: 10px 20px; font-weight: 600; height: 100%;" @(Model == null || !Model.Any() ? "disabled" : "")>
                <i class="fas fa-file-csv fa-sm text-white-50 me-2"></i> Rapor İndir
            </button>
        </form>
    </div>
</div>

<div class="card shadow mb-5" style="border-radius: 15px; border: none; overflow: hidden;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table modern-table align-middle mb-0" id="activityTable">
                <thead class="bg-light">
                    <tr>
                        <th class="border-0 px-4 w-35">Dosya Adı</th>
                        <th class="border-0 w-25">İşlem Yapan</th>
                        <th class="border-0 w-20 text-center">Aksiyon</th>
                        <th class="border-0 px-4 w-20">Tarih</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var activity in Model)
                        {
                            <tr>
                                <td class="px-4 fw-bold text-dark">
                                    @if (activity.FileExtension == "pdf")
                                    {
                                        <i class="fas fa-file-pdf text-danger me-2 fa-lg"></i>
                                    }
                                    else if (activity.FileExtension == "png" || activity.FileExtension == "jpg" || activity.FileExtension == "jpeg")
                                    {
                                        <i class="fas fa-file-image text-primary me-2 fa-lg"></i>
                                    }
                                    else if (activity.FileExtension == "xlsx" || activity.FileExtension == "xls" || activity.FileExtension == "csv")
                                    {
                                        <i class="fas fa-file-excel text-success me-2 fa-lg"></i>
                                    }
                                    else if (activity.FileExtension == "zip" || activity.FileExtension == "rar")
                                    {
                                        <i class="fas fa-file-archive text-warning me-2 fa-lg"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-file text-secondary me-2 fa-lg"></i>
                                    }
                                    @activity.FileName
                                </td>
                                <td class="text-secondary">@activity.UserEmail</td>
                                <td class="text-center">
                                    @if (activity.ActionType == "İndirme")
                                    {
                                        <span class="action-badge badge-download"><i class="fas fa-download me-1"></i> İndirme</span>
                                    }
                                    else if (activity.ActionType == "Yükleme")
                                    {
                                        <span class="action-badge badge-upload"><i class="fas fa-upload me-1"></i> Yükleme</span>
                                    }
                                    else if (activity.ActionType == "Silme")
                                    {
                                        <span class="action-badge badge-delete"><i class="fas fa-trash me-1"></i> Silme</span>
                                    }
                                    else if (activity.ActionType == "Paylaşım")
                                    {
                                        <span class="action-badge badge-share"><i class="fas fa-share me-1"></i> Paylaşım</span>
                                    }
                                    else
                                    {
                                        <span class="action-badge bg-secondary text-white"><i class="fas fa-cog me-1"></i> @activity.ActionType</span>
                                    }
                                </td>
                                <td class="px-4 text-muted small">@activity.Date</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr id="emptyRow">
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="fas fa-folder-open fa-3x mb-3 opacity-50 text-primary"></i>
                                <h5>Sistemde henüz dosya hareketi bulunmuyor.</h5>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('activitySearch').addEventListener('keyup', function() {
            let filter = this.value.toLowerCase();
            let rows = document.querySelectorAll('#activityTable tbody tr:not(#emptyRow)');
            
            rows.forEach(row => {
                let text = row.innerText.toLowerCase();
                if(text.includes(filter)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    </script>
}