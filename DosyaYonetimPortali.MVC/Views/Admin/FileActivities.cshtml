@{
    ViewData["Title"] = "Dosya Hareketleri";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 fw-bold">Sistem Dosya Hareketleri</h1>
    <div class="input-group" style="width: 300px;">
        <input type="text" class="form-control bg-white border-0 small shadow-sm" placeholder="Dosya veya eylem ara..." style="border-radius: 10px 0 0 10px;">
        <button class="btn btn-primary shadow-sm" type="button" style="border-radius: 0 10px 10px 0;">
            <i class="fas fa-search fa-sm"></i>
        </button>
    </div>
</div>

<div class="card shadow border-0" style="border-radius: 15px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted">
                    <tr>
                        <th class="border-0 px-4 py-3">Dosya Adı</th>
                        <th class="border-0 py-3">İşlem Yapan</th>
                        <th class="border-0 py-3">Aksiyon</th>
                        <th class="border-0 py-3 text-end px-4">Tarih</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="px-4 fw-bold text-dark"><i class="fas fa-file-pdf text-danger me-2"></i> Q3_Maliyet_Analizi.pdf</td>
                        <td>aysegul@coredrive.com</td>
                        <td><span class="badge bg-info rounded-pill px-3 text-white"><i class="fas fa-download me-1"></i> İndirme</span></td>
                        <td class="text-end px-4 text-muted small">01.05.2026 14:12</td>
                    </tr>
                    <tr>
                        <td class="px-4 fw-bold text-dark"><i class="fas fa-file-image text-primary me-2"></i> Logo_Yeni.png</td>
                        <td>patron@coredrive.com</td>
                        <td><span class="badge bg-success rounded-pill px-3 text-white"><i class="fas fa-upload me-1"></i> Yükleme</span></td>
                        <td class="text-end px-4 text-muted small">01.05.2026 11:30</td>
                    </tr>
                    <tr>
                        <td class="px-4 fw-bold text-dark text-decoration-line-through text-muted"><i class="fas fa-file-excel me-2"></i> Eski_Liste.xlsx</td>
                        <td>aysegul@coredrive.com</td>
                        <td><span class="badge bg-danger rounded-pill px-3 text-white"><i class="fas fa-trash me-1"></i> Silme</span></td>
                        <td class="text-end px-4 text-muted small">30.04.2026 09:15</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>