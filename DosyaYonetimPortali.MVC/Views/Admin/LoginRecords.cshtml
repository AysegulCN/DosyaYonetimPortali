@{
    ViewData["Title"] = "Giriş Kayıtları";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 fw-bold">Kullanıcı Giriş Kayıtları</h1>
    <button class="btn btn-primary shadow-sm" style="border-radius: 10px;">
        <i class="fas fa-download fa-sm text-white-50 me-1"></i> Rapor İndir (CSV)
    </button>
</div>

<div class="card shadow border-0" style="border-radius: 15px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted">
                    <tr>
                        <th class="border-0 px-4 py-3">Tarih / Saat</th>
                        <th class="border-0 py-3">Kullanıcı</th>
                        <th class="border-0 py-3">IP Adresi</th>
                        <th class="border-0 py-3">Tarayıcı / Cihaz</th>
                        <th class="border-0 py-3 text-end px-4">Durum</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="px-4 text-dark fw-bold">01.05.2026 18:05</td>
                        <td>patron@coredrive.com</td>
                        <td>192.168.1.10</td>
                        <td class="text-muted small">Chrome / Windows 11</td>
                        <td class="text-end px-4"><span class="badge bg-success rounded-pill px-3">Başarılı</span></td>
                    </tr>
                    <tr>
                        <td class="px-4 text-dark fw-bold">01.05.2026 17:42</td>
                        <td>aysegul@coredrive.com</td>
                        <td>10.0.0.55</td>
                        <td class="text-muted small">Safari / macOS</td>
                        <td class="text-end px-4"><span class="badge bg-danger rounded-pill px-3">Hatalı Şifre</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>