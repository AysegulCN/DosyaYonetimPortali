@{
    ViewData["Title"] = "Kota Yönetimi";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 fw-bold">Sistem Kota Ayarları</h1>
    <button class="btn btn-success shadow-sm" style="border-radius: 10px;">
        <i class="fas fa-save fa-sm text-white-50 me-1"></i> Değişiklikleri Kaydet
    </button>
</div>

<div class="row">
    <div class="col-lg-6 mb-4">
        <div class="card shadow border-0 h-100" style="border-radius: 15px;">
            <div class="card-body p-4">
                <h6 class="fw-bold text-primary mb-4"><i class="fas fa-hdd me-2"></i>Varsayılan Limitler</h6>
                
                <div class="mb-4">
                    <label class="form-label fw-bold text-dark">Yeni Kullanıcı Başlangıç Kotası</label>
                    <div class="input-group">
                        <input type="number" class="form-control" value="15" style="border-radius: 10px 0 0 10px;">
                        <span class="input-group-text bg-light fw-bold" style="border-radius: 0 10px 10px 0;">GB</span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-dark">Maksimum Dosya Yükleme Boyutu</label>
                    <div class="input-group">
                        <input type="number" class="form-control" value="2048" style="border-radius: 10px 0 0 10px;">
                        <span class="input-group-text bg-light fw-bold" style="border-radius: 0 10px 10px 0;">MB</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6 mb-4">
        <div class="card shadow border-0 h-100" style="border-radius: 15px;">
            <div class="card-body p-4">
                <h6 class="fw-bold text-warning mb-4"><i class="fas fa-exclamation-triangle me-2"></i>Sistem Uyarı Tetikleyicileri</h6>
                
                <div class="mb-4">
                    <label class="form-label fw-bold text-dark">Kullanıcı Kota Uyarı Sınırı</label>
                    <div class="input-group">
                        <input type="number" class="form-control" value="85" style="border-radius: 10px 0 0 10px;">
                        <span class="input-group-text bg-light fw-bold" style="border-radius: 0 10px 10px 0;">%</span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-dark">Sunucu Kritik Doluluk Alarmı</label>
                    <div class="input-group">
                        <input type="number" class="form-control" value="90" style="border-radius: 10px 0 0 10px;">
                        <span class="input-group-text bg-light fw-bold" style="border-radius: 0 10px 10px 0;">%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>