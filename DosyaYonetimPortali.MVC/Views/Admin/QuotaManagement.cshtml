@model DosyaYonetimPortali.MVC.Models.QuotaSettingsViewModel
@{
    ViewData["Title"] = "Kota Yönetimi";
    Layout = "~/Views/Shared/_Layout.cshtml"; 
    long currentQuotaMB = ViewBag.CurrentQuotaMB;
    int currentQuotaGB = (int)(currentQuotaMB / 1024);
    int pendingGB = ViewBag.PendingRequestGB;
}

<div class="container-fluid mt-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h3 class="m-0 font-weight-bold text-dark"><i class="fas fa-server text-primary mr-3"></i>Kota ve Depolama Yönetimi</h3>
        <a href="/?preview=true" class="btn btn-outline-primary font-weight-bold" style="border-radius: 20px;"><i class="fas fa-external-link-alt mr-2"></i>Siteye Göz At</a>
    </div>

    @if (TempData["ToastMessage"] != null)
    {
        <div class="alert @(TempData["ToastIcon"].ToString() == "success" ? "alert-success" : "alert-danger") alert-dismissible fade show border-0 shadow-sm mb-4" style="border-radius: 8px;">
            <i class="fas @(TempData["ToastIcon"].ToString() == "success" ? "fa-check-circle" : "fa-times-circle") mr-2"></i> @TempData["ToastMessage"]
            <button type="button" class="close text-dark" data-dismiss="alert" style="outline: none;"><span>&times;</span></button>
        </div>
    }

    <div class="row">
        <div class="col-xl-6 col-lg-6 mb-4">
            <div class="card border-0 shadow-sm" style="border-radius: 12px;">
                <div class="card-header border-0 bg-transparent pt-4 pb-0 px-4">
                    <h5 class="font-weight-bold text-dark m-0">Onay Bekleyen Kota Talepleri</h5>
                </div>
                <div class="card-body p-4">
                    @if (pendingGB > 0)
                    {
                        <div class="d-flex align-items-center justify-content-between p-3" style="border: 1px solid #dadce0; border-radius: 8px; background-color: #f8f9fa;">
                            <div class="d-flex align-items-center">
                                <div class="bg-warning text-dark rounded-circle d-flex justify-content-center align-items-center mr-3" style="width: 48px; height: 48px; font-size: 20px;">
                                    <i class="fas fa-hourglass-half"></i>
                                </div>
                                <div>
                                    <h6 class="m-0 font-weight-bold text-dark">Kullanıcı (Genel)</h6>
                                    <small class="text-muted">Mevcut: @currentQuotaGB GB <i class="fas fa-arrow-right mx-1"></i> <strong>Talep Edilen: @pendingGB GB</strong></small>
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <form asp-action="RejectQuotaRequest" method="post" class="m-0 mr-2">
                                    <button type="submit" class="btn btn-outline-danger" style="border-radius: 8px; font-weight: 600;"><i class="fas fa-times mr-1"></i> Reddet</button>
                                </form>
                                <form asp-action="ApproveQuotaRequest" method="post" class="m-0">
                                    <button type="submit" class="btn btn-success" style="border-radius: 8px; font-weight: 600;"><i class="fas fa-check mr-1"></i> Onayla</button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-check-circle text-success mb-3" style="font-size: 40px; opacity: 0.5;"></i>
                            <h6 class="text-muted">Bekleyen bir kota talebi bulunmuyor.</h6>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-6 col-lg-6 mb-4">
            <div class="card border-0 shadow-sm" style="border-radius: 12px;">
                <div class="card-header border-0 bg-transparent pt-4 pb-0 px-4">
                    <h5 class="font-weight-bold text-dark m-0">Kullanıcı Kotalarını Yönet (Zorla Değiştir)</h5>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex align-items-center p-3 mb-3" style="border: 1px solid #dadce0; border-radius: 8px;">
                        <h4 class="m-0 font-weight-bold text-primary mr-auto">@currentQuotaGB <span style="font-size: 16px;">GB</span></h4>
                        <span class="badge badge-primary px-3 py-2" style="border-radius: 20px;">Mevcut Aktif Kota</span>
                    </div>
                    <div class="d-flex justify-content-between mt-4">
                        <form asp-action="ForceSetQuota" method="post" class="w-100 mr-2">
                            <input type="hidden" name="targetGB" value="15" />
                            <button type="submit" class="btn @(currentQuotaGB == 15 ? "btn-secondary disabled" : "btn-outline-danger") w-100" style="border-radius: 8px; font-weight: 600;"><i class="fas fa-arrow-down mr-1"></i> 15 GB'a Düşür</button>
                        </form>
                        <form asp-action="ForceSetQuota" method="post" class="w-100 mr-2">
                            <input type="hidden" name="targetGB" value="50" />
                            <button type="submit" class="btn @(currentQuotaGB == 50 ? "btn-secondary disabled" : "btn-outline-primary") w-100" style="border-radius: 8px; font-weight: 600;">50 GB Yap</button>
                        </form>
                        <form asp-action="ForceSetQuota" method="post" class="w-100">
                            <input type="hidden" name="targetGB" value="250" />
                            <button type="submit" class="btn @(currentQuotaGB == 250 ? "btn-secondary disabled" : "btn-outline-primary") w-100" style="border-radius: 8px; font-weight: 600;"><i class="fas fa-arrow-up mr-1"></i> 250 GB Yap</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>