                                <span class="fw-bold text-dark">Sistem Yöneticisi</span>
                            </div>
                        </td>
                        <td class="text-secondary"><i class="fas fa-user-shield text-primary me-2"></i> Kullanıcı yetkilerini güncelledi (ID: #0045)</td>
                        <td class="text-muted small"><i class="far fa-clock me-1 text-gray-400"></i> 22 dakika önce</td>
                        <td class="text-end px-4"><span class="badge bg-primary modern-badge rounded-pill">Admin İşlemi</span></td>
                    </tr>
                    <tr>
                        <td class="px-4">
                            <div class="d-flex align-items-center">
                                <img src="https://ui-avatars.com/api/?name=Mehmet+K&background=fff8e1&color=f57f17&rounded=true" class="shadow-sm me-3" width="38" height="38">
                                <span class="fw-bold text-dark">Mehmet K.</span>
                            </div>
                        </td>
