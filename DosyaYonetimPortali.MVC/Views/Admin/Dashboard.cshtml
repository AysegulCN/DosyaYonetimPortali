                        <td class="text-muted small"><i class="far fa-clock me-1 text-gray-400"></i> 1 saat önce</td>
                        <td class="text-end px-4"><span class="badge bg-danger modern-badge rounded-pill">Kota Aşıldı</span></td>
                    </tr>
                    <tr>
                        <td class="px-4">
                            <div class="d-flex align-items-center">
                                <img src="https://ui-avatars.com/api/?name=Sistem+Oto&background=e0f2f1&color=004d40&rounded=true" class="shadow-sm me-3" width="38" height="38">
