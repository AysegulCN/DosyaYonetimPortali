@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
   .btn-animated:active {
        transform: scale(0.95);
    }
    
    .modern-table tbody tr {
        transition: all 0.25s ease-in-out;
        border-bottom: 1px solid #f1f3f5;
    }
    .modern-table tbody tr:hover {
        background-color: #ffffff;
        box-shadow: 0 6px 15px rgba(0,0,0,0.08);
        transform: translateY(-2px);
        z-index: 10;
        position: relative;
    }
    .modern-table td {
        border-top: none !important; 
        padding: 1.25rem 1rem !important; 
        vertical-align: middle;
    }
    .modern-badge {
        font-weight: 600;
        letter-spacing: 0.5px;
        padding: 8px 16px !important;
        box-shadow: 0 3px 5px rgba(0,0,0,0.05);
    }

    .modern-stat-card {
        border: none !important;
        border-radius: 15px !important;
        box-shadow: 0 4px 10px rgba(0,0,0,0.03) !important;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        position: relative;
        overflow: hidden;
        background-color: #fff;
    }
    .modern-stat-card::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 5px;
        border-radius: 15px 0 0 15px;
    }
    .modern-stat-card.primary-card::before { background: linear-gradient(180deg, #4e73df 0%, #224abe 100%); }
    .modern-stat-card.success-card::before { background: linear-gradient(180deg, #1cc88a 0%, #13855c 100%); }
    .modern-stat-card.info-card::before { background: linear-gradient(180deg, #36b9cc 0%, #258391 100%); }
    .modern-stat-card.warning-card::before { background: linear-gradient(180deg, #f6c23e 0%, #dda20a 100%); }

    .modern-stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.08) !important;
    }
    .modern-stat-card .icon-circle {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    }
    .modern-stat-card:hover .icon-circle {
        transform: scale(1.15) rotate(5deg);
    }
    .icon-primary { background-color: rgba(78, 115, 223, 0.1); color: #4e73df; }
    .icon-success { background-color: rgba(28, 200, 138, 0.1); color: #1cc88a; }
    .icon-info { background-color: rgba(54, 185, 204, 0.1); color: #36b9cc; }
    .icon-warning { background-color: rgba(246, 194, 62, 0.1); color: #f6c23e; }
</style>

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 fw-bold">Sistem Genel Özeti</h1>
    
    <form asp-action="GenerateSystemReport" asp-controller="Admin" method="post" class="d-inline">
        <button type="submit" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm btn-animated" style="border-radius: 8px; padding: 8px 15px;" onclick="this.querySelector('i').classList.add('fa-spin');">
            <i class="fas fa-download fa-sm text-white-50 me-1"></i> Sistem Raporu Al
        </button>
    </form>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert" style="border-radius: 10px;">
        <i class="fas fa-check-circle me-2"></i> @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-4 mb-xl-0">
        <a href="/Admin/Users" class="text-decoration-none">
            <div class="card modern-stat-card primary-card h-100 py-3">
                <div class="card-body px-4">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1" style="letter-spacing: 0.8px;">Toplam Kullanıcı</div>
                            <div class="h3 mb-0 font-weight-bold text-gray-800">124</div>
                        </div>
                        <div class="col-auto">
                            <div class="icon-circle icon-primary">
                                <i class="fas fa-users fa-lg"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-xl-3 col-md-6 mb-4 mb-xl-0">
        <a href="/Admin/FileActivities" class="text-decoration-none">
            <div class="card modern-stat-card success-card h-100 py-3">
                <div class="card-body px-4">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1" style="letter-spacing: 0.8px;">Yüklenen Dosyalar</div>
                            <div class="h3 mb-0 font-weight-bold text-gray-800">3,458</div>
                        </div>
                        <div class="col-auto">
                            <div class="icon-circle icon-success">
                                <i class="fas fa-file-alt fa-lg"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-xl-3 col-md-6 mb-4 mb-xl-0">
        <a href="/Admin/Storage" class="text-decoration-none">
            <div class="card modern-stat-card info-card h-100 py-3">
                <div class="card-body px-4">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1" style="letter-spacing: 0.8px;">Depolama (500GB)</div>
                            <div class="row no-gutters align-items-center">
                                <div class="col-auto">
                                    <div class="h3 mb-0 mr-3 font-weight-bold text-gray-800">45%</div>
                                </div>
                                <div class="col">
                                    <div class="progress progress-sm mr-2" style="border-radius: 10px;">
                                        <div class="progress-bar bg-info" style="width: 45%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-auto">
                            <div class="icon-circle icon-info">
                                <i class="fas fa-hdd fa-lg"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-xl-3 col-md-6 mb-4 mb-xl-0">
        <a href="/Admin/Shares" class="text-decoration-none">
            <div class="card modern-stat-card warning-card h-100 py-3">
                <div class="card-body px-4">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1" style="letter-spacing: 0.8px;">Aktif Paylaşımlar</div>
                            <div class="h3 mb-0 font-weight-bold text-gray-800">86</div>
                        </div>
                        <div class="col-auto">
                            <div class="icon-circle icon-warning">
                                <i class="fas fa-link fa-lg"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

