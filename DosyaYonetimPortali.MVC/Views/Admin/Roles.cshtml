@{
    ViewData["Title"] = "Rol Yönetimi";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Yetki ve Rol Yönetimi</h1>
    <button class="btn btn-primary shadow-sm" data-toggle="modal" data-target="#addRoleModal">
        <i class="fas fa-plus fa-sm text-white-50"></i> Yeni Rol Ekle
    </button>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Mevcut Sistem Rolleri</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered" id="rolesTable" width="100%" cellspacing="0">
                        <thead class="bg-light">
                            <tr>
                                <th>Rol Adı</th>
                                <th>Açıklama / Yetki Seviyesi</th>
                                <th class="text-center">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><span class="badge badge-danger p-2">Admin</span></td>
                                <td>Tam Sistem Erişimi (Tüm dosyalar ve kullanıcılar)</td>
                                <td class="text-center"><small class="text-muted">Sistem Rolü (Silinemez)</small></td>
                            </tr>
                            <tr>
                                <td><span class="badge badge-warning p-2 text-dark">Moderatör</span></td>
                                <td>Kullanıcı izleme ve dosya denetimi yetkisi</td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td><span class="badge badge-primary p-2">User</span></td>
                                <td>Standart kullanıcı (Kendi alanıyla sınırlı)</td>
                                <td class="text-center"><small class="text-muted">Sistem Rolü (Silinemez)</small></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addRoleModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Sisteme Yeni Rol Tanımla</h5>
                <button class="close text-white" type="button" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="font-weight-bold small">Rol Adı</label>
                    <input type="text" class="form-control" placeholder="Örn: Editor, Support...">
                </div>
                <div class="form-group">
                    <label class="font-weight-bold small">Yetki Açıklaması</label>
                    <textarea class="form-control" rows="3" placeholder="Bu role sahip kişiler ne yapabilir?"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" type="button" data-dismiss="modal">Vazgeç</button>
                <button class="btn btn-primary" onclick="alert('Rol başarıyla oluşturuldu!')">Rolü Kaydet</button>
            </div>
        </div>
    </div>
</div>