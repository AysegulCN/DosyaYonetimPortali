@model List<DosyaYonetimPortali.MVC.Models.RoleViewModel>
@{
    ViewData["Title"] = "Sistem Rolleri";
}

<style>
    .btn-animated:active { transform: scale(0.95); }
    .modern-table tbody tr { transition: all 0.25s ease-in-out; border-bottom: 1px solid #f1f3f5; }
    .modern-table tbody tr:hover { background-color: #ffffff; box-shadow: 0 6px 15px rgba(0,0,0,0.08); transform: translateY(-2px); z-index: 10; position: relative; }
    .modern-table td { border-top: none !important; padding: 1.25rem 1rem !important; vertical-align: middle; }
    .modern-input { border-radius: 10px; padding: 0.75rem 1rem; border: 1px solid #d1d3e2; height: 52px; }
    .modern-input:focus { border-color: #4e73df; box-shadow: 0 0 0 0.25rem rgba(78, 115, 223, 0.1); outline: none; }
    
    /* Özel Kapatma (X) Butonu Tasarımı */
    .custom-close-btn {
        background: #f8f9fc; border: none; border-radius: 50%; width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center; color: #858796; transition: all 0.2s;
    }
    .custom-close-btn:hover { background: #e74a3b; color: white; }
</style>

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 fw-bold">Sistem Rolleri</h1>
    <!-- Bootstrap 4 ve 5 uyumlu toggle -->
    <button type="button" class="btn btn-primary shadow-sm btn-animated" data-bs-toggle="modal" data-toggle="modal" data-bs-target="#addRoleModal" data-target="#addRoleModal" style="border-radius: 10px; padding: 8px 15px;">
        <i class="fas fa-plus fa-sm text-white-50 me-1"></i> Yeni Rol Ekle
    </button>
</div>

<div class="card shadow mb-5" style="border-radius: 15px; border: none; overflow: hidden;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table modern-table align-middle mb-0">
                <thead class="bg-light" style="color: #858796; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">
                    <tr>
                        <th class="border-0 px-4 py-3">Rol Adı</th>
                        <th class="border-0 py-3">Kullanıcı Sayısı</th>
                        <th class="border-0 py-3">Durum</th>
                        <th class="border-0 py-3 text-end px-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in Model)
                    {
                        <tr>
                            <td class="px-4 fw-bold @(role.IsSystemRole ? "text-danger" : "text-primary")">@role.RoleName</td>
                            <td class="text-secondary">@role.UserCount</td>
                            <td><span class="badge bg-success rounded-pill px-3 py-2 shadow-sm">Aktif</span></td>
                            <td class="text-end px-4">
                                @if (role.IsSystemRole)
                                {
                                    <button type="button" class="btn btn-sm btn-light text-muted shadow-sm" title="Sistem çekirdek rolü değiştirilemez" style="cursor: not-allowed;">
                                        <i class="fas fa-lock"></i>
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-outline-info shadow-sm me-1 btn-animated" title="Düzenle" onclick="openEditModal('@role.RoleName')">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    
                                    <form asp-action="DeleteRole" asp-controller="Admin" method="post" class="d-inline">
                                        <input type="hidden" name="RoleName" value="@role.RoleName" />
                                        <button type="button" class="btn btn-sm btn-outline-danger shadow-sm btn-animated" title="Sil" onclick="confirmAction(event, this.closest('form'), '@role.RoleName rolünü silmek istediğinize emin misiniz?', 'Evet, Sil', '#e74a3b')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- YENİ ROL EKLE MODAL PENCERESİ -->
<div class="modal fade" id="addRoleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 15px; border: none;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-primary"><i class="fas fa-plus-circle me-2"></i>Yeni Rol Oluştur</h5>
                <!-- Sorunlu (-) işareti yerine garantili FontAwesome X butonu -->
                <button type="button" class="custom-close-btn" data-bs-dismiss="modal" data-dismiss="modal" aria-label="Close">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <form asp-action="AddRole" asp-controller="Admin" method="post">
                <div class="modal-body py-4">
                    <label class="form-label fw-bold text-dark small text-uppercase" style="letter-spacing: 0.5px;">Rol Adı</label>
                    <input type="text" name="RoleName" class="form-control modern-input" placeholder="Örn: Editör, Muhasebe..." required autocomplete="off">
                </div>
                <div class="modal-footer border-0 pt-0">
                    <!-- Hem data-dismiss hem data-bs-dismiss eklendi (Her versiyonda çalışır) -->
                    <button type="button" class="btn btn-light shadow-sm" data-bs-dismiss="modal" data-dismiss="modal" style="border-radius: 10px;">İptal</button>
                    <button type="submit" class="btn btn-primary shadow-sm btn-animated" style="border-radius: 10px;">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ROL DÜZENLE MODAL PENCERESİ -->
<div class="modal fade" id="editRoleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 15px; border: none;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-info"><i class="fas fa-edit me-2"></i>Rolü Düzenle</h5>
                <button type="button" class="custom-close-btn" data-bs-dismiss="modal" data-dismiss="modal" aria-label="Close">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <form asp-action="EditRole" asp-controller="Admin" method="post">
                <div class="modal-body py-4">
                    <input type="hidden" name="OldRoleName" id="editOldRoleName" />
                    <label class="form-label fw-bold text-dark small text-uppercase" style="letter-spacing: 0.5px;">Yeni Rol Adı</label>
                    <input type="text" name="NewRoleName" id="editNewRoleName" class="form-control modern-input" required autocomplete="off">
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light shadow-sm" data-bs-dismiss="modal" data-dismiss="modal" style="border-radius: 10px;">İptal</button>
                    <button type="submit" class="btn btn-info text-white shadow-sm btn-animated" style="border-radius: 10px;">Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function openEditModal(roleName) {
            document.getElementById('editOldRoleName').value = roleName;
            document.getElementById('editNewRoleName').value = roleName;
            // Bootstrap 4 ve 5 uyumlu modal açma yöntemi (jQuery ile)
            $('#editRoleModal').modal('show');
        }

        function confirmAction(event, form, message, confirmText, color) {
            event.preventDefault();
            Swal.fire({
                title: 'Emin misiniz?',
                text: message,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: color,
                cancelButtonColor: '#858796',
                confirmButtonText: confirmText,
                cancelButtonText: 'Vazgeç',
                reverseButtons: true,
                borderRadius: '15px'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        }

        @if (TempData["ToastMessage"] != null)
        {
            <text>
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 4000, /* Tam 4 saniye ekranda kalacak */
                timerProgressBar: true,
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer)
                    toast.addEventListener('mouseleave', Swal.resumeTimer)
                }
            });

            Toast.fire({
                icon: '@TempData["ToastIcon"]',
                title: '@TempData["ToastMessage"]'
            });
            </text>
        }
    </script>
}