@{
    ViewData["Title"] = "Rol Yönetimi";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 fw-bold">Sistem Rolleri</h1>
    <button class="btn btn-primary shadow-sm" style="border-radius: 10px;">
        <i class="fas fa-plus fa-sm text-white-50 me-1"></i> Yeni Rol Ekle
    </button>
</div>

<div class="card shadow mb-4 border-0" style="border-radius: 15px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted">
                    <tr>
                        <th class="border-0 px-4 py-3">Rol Adı</th>
                        <th class="border-0 py-3">Kullanıcı Sayısı</th>
                        <th class="border-0 py-3">Durum</th>
                        <th class="border-0 py-3 text-end px-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="px-4 fw-bold text-danger">Admin</td>
                        <td>2</td>
                        <td><span class="badge bg-success rounded-pill px-3">Aktif</span></td>
                        <td class="text-end px-4">
                            <button class="btn btn-sm btn-outline-secondary shadow-sm" disabled><i class="fas fa-lock"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td class="px-4 fw-bold text-primary">User</td>
                        <td>122</td>
                        <td><span class="badge bg-success rounded-pill px-3">Aktif</span></td>
                        <td class="text-end px-4">
                            <button class="btn btn-sm btn-outline-info shadow-sm me-1"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-outline-danger shadow-sm"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>