@{
    ViewData["Title"] = "Dosya Ayarları";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 fw-bold">Dosya İzinleri ve Güvenlik</h1>
    <button class="btn btn-success shadow-sm" style="border-radius: 10px;">
        <i class="fas fa-save fa-sm text-white-50 me-1"></i> Ayarları Kaydet
    </button>
</div>

<div class="row">
    <div class="col-lg-12 mb-4">
        <div class="card shadow border-0" style="border-radius: 15px;">
            <div class="card-body p-4">
                
                <h6 class="fw-bold text-primary mb-3"><i class="fas fa-check-circle me-2"></i>İzin Verilen Uzantılar (Beyaz Liste)</h6>
                <div class="mb-4">
                    <input type="text" class="form-control" value=".jpg, .png, .pdf, .docx, .xlsx, .zip, .rar, .mp4" style="border-radius: 10px;">
                </div>
                
                <h6 class="fw-bold text-danger mb-3"><i class="fas fa-ban me-2"></i>Yasaklı Uzantılar (Kara Liste)</h6>
                <div class="mb-4">
                    <input type="text" class="form-control" value=".exe, .bat, .cmd, .sh, .js, .vbs" style="border-radius: 10px;">
                </div>

                <div class="d-flex justify-content-between align-items-center border-top pt-3 pb-3">
                    <div>
                        <div class="fw-bold text-dark">Otomatik Virüs Taraması</div>
                        <div class="small text-muted">Sisteme yüklenen her dosya arka planda güvenlik taramasından geçirilir.</div>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch" checked style="transform: scale(1.5);">
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center border-top pt-3">
                    <div>
                        <div class="fw-bold text-dark">Aynı İsimli Dosyaların Üzerine Yaz</div>
                        <div class="small text-muted">Aynı isimde dosya yüklendiğinde eski dosyayı silip yenisini kaydeder.</div>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch" style="transform: scale(1.5);">
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>