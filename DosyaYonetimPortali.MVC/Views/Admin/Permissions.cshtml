@model List<DosyaYonetimPortali.MVC.Models.PermissionViewModel>
@{
    ViewData["Title"] = "Yetki Matrisi";
}

<style>
    .btn-animated:active { transform: scale(0.95); }
    .modern-table tbody tr { transition: all 0.25s ease-in-out; border-bottom: 1px solid #f1f3f5; }
    .modern-table tbody tr:hover { background-color: #f8f9fc; }
    .modern-table td { border-top: none !important; padding: 1.25rem 1rem !important; vertical-align: middle; font-weight: 500; color: #5a5c69; }
    .modern-table th { font-weight: 700; color: #858796; text-transform: uppercase; letter-spacing: 1px; font-size: 0.85rem; padding: 1.5rem 1rem; }
    .core-badge { font-size: 0.7rem; padding: 4px 8px; margin-left: 10px; background-color: #e74a3b; color: white; border-radius: 12px; font-weight: bold; }
    .custom-checkbox { width: 1.5rem; height: 1.5rem; cursor: pointer; }
    .custom-checkbox:disabled { opacity: 0.5; cursor: not-allowed; }
    .modern-input { border-radius: 10px; padding: 0.75rem 1rem; border: 1px solid #d1d3e2; height: 52px; }
    .modern-input:focus { border-color: #4e73df; box-shadow: 0 0 0 0.25rem rgba(78, 115, 223, 0.1); outline: none; }
    .custom-close-btn { background: #f8f9fc; border: none; border-radius: 50%; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; color: #858796; transition: all 0.2s; }
    .custom-close-btn:hover { background: #e74a3b; color: white; }
    .option-input { display: none; }
    .option-card { border: 2px solid #eaecf4; border-radius: 12px; padding: 1.25rem; cursor: pointer; transition: all 0.2s ease-in-out; height: 100%; }
    .option-card:hover { border-color: #d1d3e2; }
    .option-input:checked + .option-card.free-type { border-color: #4e73df; background-color: #f0f4ff; }
    .option-input:checked + .option-card.core-type { border-color: #e74a3b; background-color: #fdf3f2; }
</style>

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 fw-bold">Sistem Yetki Matrisi</h1>
    <div>
        <button type="button" class="btn btn-primary shadow-sm btn-animated me-2" data-bs-toggle="modal" data-bs-target="#addPermissionModal" data-toggle="modal" data-target="#addPermissionModal" style="border-radius: 10px; padding: 10px 15px; font-weight: 600;">
            <i class="fas fa-plus fa-sm text-white-50 me-2"></i> Yeni Yetki Ekle
        </button>
        <button type="button" onclick="document.getElementById('savePermissionsForm').submit();" class="btn btn-success shadow-sm btn-animated" style="border-radius: 10px; padding: 10px 20px; font-weight: 600;">
            <i class="fas fa-save fa-sm text-white-50 me-2"></i> Değişiklikleri Kaydet
        </button>
    </div>
</div>

<form id="savePermissionsForm" asp-action="SavePermissions" asp-controller="Admin" method="post">
    <div class="card shadow mb-5" style="border-radius: 15px; border: none; overflow: hidden;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table modern-table align-middle mb-0 text-center">
                    <thead class="bg-light">
                        <tr>
                            <th class="border-0 text-start px-5 w-40">Sistem Modülü / Özellik</th>
                            @foreach (var role in ViewBag.Roles)
                            {
                                <th class="border-0"><i class="fas fa-user-shield me-2"></i>@role.RoleName</th>
                            }
                            <th class="border-0 text-end px-5 w-20">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            <tr>
                                <td class="text-start px-5">
                                    <input type="hidden" asp-for="@Model[i].ModuleName" />
                                    <input type="hidden" asp-for="@Model[i].IsCore" />
                                    <span style="font-size: 1.05rem;">@Model[i].ModuleName</span>
                                    @if (Model[i].IsCore)
                                    {
                                        <span class="core-badge">ÇEKİRDEK</span>
                                    }
                                </td>
                                
                                @for (int j = 0; j < Model[i].RoleAccesses.Count; j++)
                                {
                                    <td>
                                        <input type="hidden" asp-for="@Model[i].RoleAccesses[j].RoleName" />
                                        @{
                                            bool isDisabled = Model[i].IsCore && Model[i].RoleAccesses[j].RoleName == "Admin";
                                        }
                                        <input class="form-check-input custom-checkbox" type="checkbox" asp-for="@Model[i].RoleAccesses[j].HasAccess" disabled="@(isDisabled ? "disabled" : null)">
                                        
                                        @if (isDisabled)
                                        {
                                            <input type="hidden" asp-for="@Model[i].RoleAccesses[j].HasAccess" value="true" />
                                        }
                                    </td>
                                }

                                <td class="text-end px-5">
                                    <button type="button" class="btn btn-sm btn-outline-danger shadow-sm btn-animated" onclick="deleteModule('@Model[i].ModuleName', @Model[i].IsCore.ToString().ToLower())">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</form>

<form id="deletePermissionForm" asp-action="DeletePermission" asp-controller="Admin" method="post" style="display: none;">
    <input type="hidden" name="ModuleName" id="deleteModuleName" />
</form>

<div class="modal fade" id="addPermissionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" style="border-radius: 15px; border: none;">
            <div class="modal-header border-0 pb-0 mt-3 px-4">
                <h5 class="modal-title fw-bold text-primary"><i class="fas fa-layer-group me-2"></i>Yeni Sistem Yetkisi Ekle</h5>
                <button type="button" class="custom-close-btn" data-bs-dismiss="modal" data-dismiss="modal" aria-label="Close">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <form asp-action="AddPermission" asp-controller="Admin" method="post">
                <div class="modal-body py-4 px-4">
                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark small text-uppercase" style="letter-spacing: 0.5px;">Yetki / Modül Adı</label>
                        <input type="text" name="ModuleName" class="form-control modern-input" required autocomplete="off">
                    </div>
                    <label class="form-label fw-bold text-dark small text-uppercase mb-3" style="letter-spacing: 0.5px;">Modül Tipi (Seviyesi)</label>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="w-100 h-100">
                                <input type="radio" name="ModuleType" value="Free" class="option-input" checked>
                                <div class="option-card free-type">
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                            <i class="fas fa-unlock"></i>
                                        </div>
                                        <h6 class="fw-bold mb-0 text-dark">Serbest Modül</h6>
                                    </div>
                                </div>
                            </label>
                        </div>
                        <div class="col-md-6">
                            <label class="w-100 h-100">
                                <input type="radio" name="ModuleType" value="Core" class="option-input">
                                <div class="option-card core-type">
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                            <i class="fas fa-lock"></i>
                                        </div>
                                        <h6 class="fw-bold mb-0 text-dark">Çekirdek Modül</h6>
                                    </div>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 px-4 mb-3">
                    <button type="button" class="btn btn-light shadow-sm" data-bs-dismiss="modal" data-dismiss="modal" style="border-radius: 10px;">İptal</button>
                    <button type="submit" class="btn btn-primary shadow-sm btn-animated" style="border-radius: 10px; padding: 8px 25px;">Kayıt Oluştur</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteModule(moduleName, isCore) {
            if (isCore) {
                Swal.fire({
                    title: 'Güvenlik Doğrulaması',
                    text: 'Çekirdek modülü silmek için yönetici şifresini girin:',
                    input: 'password',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#e74a3b',
                    cancelButtonColor: '#858796',
                    confirmButtonText: 'Doğrula ve Sil',
                    cancelButtonText: 'İptal',
                    borderRadius: '15px'
                }).then((result) => {
                    if (result.isConfirmed) {
                        if (result.value === "12345") {
                            document.getElementById('deleteModuleName').value = moduleName;
                            document.getElementById('deletePermissionForm').submit();
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Hatalı Şifre',
                                text: 'Şifre yanlış. İşlem reddedildi.',
                                confirmButtonColor: '#4e73df'
                            });
                        }
                    }
                });
            } else {
                Swal.fire({
                    title: 'Emin misiniz?',
                    text: 'Bu serbest modülü kalıcı olarak silmek üzeresiniz.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#e74a3b',
                    cancelButtonColor: '#858796',
                    confirmButtonText: 'Evet, Sil',
                    cancelButtonText: 'Vazgeç',
                    reverseButtons: true,
                    borderRadius: '15px'
                }).then((result) => {
                    if (result.isConfirmed) {
                        document.getElementById('deleteModuleName').value = moduleName;
                        document.getElementById('deletePermissionForm').submit();
                    }
                });
            }
        }

        @if (TempData["ToastMessage"] != null)
        {
            <text>
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 4000,
                timerProgressBar: true,
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer)
                    toast.addEventListener('mouseleave', Swal.resumeTimer)
                }
            });
            Toast.fire({
                icon: '@TempData["ToastIcon"]',
                title: '@TempData["ToastMessage"]'
            });
            </text>
        }
    </script>
}