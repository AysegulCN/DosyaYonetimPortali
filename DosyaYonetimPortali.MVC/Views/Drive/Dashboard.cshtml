@{
    ViewData["Title"] = "Dosyalarım";
}

<!-- Üst Bar: Başlık ve Yeni Ekle Butonu -->
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 fw-bold"><i class="fas fa-hdd text-primary me-2"></i> Dosyalarım</h1>
    
    <!-- Yükleme Dropdown Menüsü -->
    <div class="dropdown">
        <button class="btn btn-primary shadow-sm dropdown-toggle" type="button" id="uploadDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="border-radius: 20px; padding: 8px 20px;">
            <i class="fas fa-plus fa-sm text-white-50 me-1"></i> Yeni
        </button>
        <ul class="dropdown-menu shadow border-0" aria-labelledby="uploadDropdown" style="border-radius: 10px;">
            <li><a class="dropdown-item py-2" href="#"><i class="fas fa-folder-plus text-muted me-2"></i> Yeni Klasör</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item py-2" href="#"><i class="fas fa-file-upload text-primary me-2"></i> Dosya Yükle</a></li>
        </ul>
    </div>
</div>

<!-- Dizin Yolu (Breadcrumb) -->
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb bg-white shadow-sm" style="border-radius: 10px;">
        <li class="breadcrumb-item"><a href="/Drive/Dashboard" class="text-decoration-none"><i class="fas fa-home"></i> Ana Dizin</a></li>
    </ol>
</nav>

<!-- KLASÖRLER BÖLÜMÜ -->
<h6 class="text-muted fw-bold mb-3 text-uppercase" style="letter-spacing: 1px;">Klasörler</h6>
<div class="row mb-4">
    <!-- Klasör 1 -->
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card shadow-sm border-0 folder-card" style="border-radius: 15px; cursor: pointer; transition: transform 0.2s;">
            <div class="card-body p-3 d-flex align-items-center">
                <i class="fas fa-folder fa-2x text-warning me-3"></i>
                <div class="text-dark fw-bold text-truncate">Finans Raporları</div>
            </div>
        </div>
    </div>
    
    <!-- Klasör 2 -->
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card shadow-sm border-0 folder-card" style="border-radius: 15px; cursor: pointer; transition: transform 0.2s;">
            <div class="card-body p-3 d-flex align-items-center">
                <i class="fas fa-folder-shared fa-2x text-primary me-3"></i>
                <div class="text-dark fw-bold text-truncate">Projeler (Ortak)</div>
            </div>
        </div>
    </div>
</div>

<!-- DOSYALAR BÖLÜMÜ -->
<h6 class="text-muted fw-bold mb-3 text-uppercase" style="letter-spacing: 1px;">Son Yüklenen Dosyalar</h6>
<div class="card shadow-sm border-0" style="border-radius: 15px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted">
                    <tr>
                        <th class="border-0 px-4 py-3">Adı</th>
                        <th class="border-0 py-3">Boyut</th>
                        <th class="border-0 py-3 d-none d-md-table-cell">Son Değişiklik</th>
                        <th class="border-0 py-3 text-end px-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- PDF Dosyası -->
                    <tr>
                        <td class="px-4">
                            <i class="fas fa-file-pdf fa-lg text-danger me-3"></i>
                            <span class="text-dark fw-bold">Q3_Maliyet_Analizi.pdf</span>
                        </td>
                        <td>2.4 MB</td>
                        <td class="text-muted d-none d-md-table-cell">Bugün, 14:30</td>
                        <td class="text-end px-4">
                            <button class="btn btn-sm btn-light text-primary rounded-circle me-1" title="İndir"><i class="fas fa-download"></i></button>
                            <button class="btn btn-sm btn-light text-success rounded-circle me-1" title="Paylaş"><i class="fas fa-share-alt"></i></button>
                            <button class="btn btn-sm btn-light text-danger rounded-circle" title="Sil"><i class="fas fa-trash-alt"></i></button>
                        </td>
                    </tr>
                    
                    <!-- Resim Dosyası -->
                    <tr>
                        <td class="px-4">
                            <i class="fas fa-file-image fa-lg text-info me-3"></i>
                            <span class="text-dark fw-bold">Logo_Tasarim_v2.png</span>
                        </td>
                        <td>850 KB</td>
                        <td class="text-muted d-none d-md-table-cell">Dün, 09:15</td>
                        <td class="text-end px-4">
                            <button class="btn btn-sm btn-light text-primary rounded-circle me-1"><i class="fas fa-download"></i></button>
                            <button class="btn btn-sm btn-light text-success rounded-circle me-1"><i class="fas fa-share-alt"></i></button>
                            <button class="btn btn-sm btn-light text-danger rounded-circle"><i class="fas fa-trash-alt"></i></button>
                        </td>
                    </tr>
                    
                    <!-- Excel Dosyası -->
                    <tr>
                        <td class="px-4">
                            <i class="fas fa-file-excel fa-lg text-success me-3"></i>
                            <span class="text-dark fw-bold">Musteri_Listesi_2026.xlsx</span>
                        </td>
                        <td>1.2 MB</td>
                        <td class="text-muted d-none d-md-table-cell">24 Nisan 2026</td>
                        <td class="text-end px-4">
                            <button class="btn btn-sm btn-light text-primary rounded-circle me-1"><i class="fas fa-download"></i></button>
                            <button class="btn btn-sm btn-light text-success rounded-circle me-1"><i class="fas fa-share-alt"></i></button>
                            <button class="btn btn-sm btn-light text-danger rounded-circle"><i class="fas fa-trash-alt"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .folder-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
    }
</style>