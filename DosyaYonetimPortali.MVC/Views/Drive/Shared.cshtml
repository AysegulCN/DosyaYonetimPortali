@model List<DosyaYonetimPortali.MVC.Models.DriveItemViewModel>
@{
    ViewData["Title"] = "Benimle Paylaşılanlar"; Layout = "~/Views/Shared/_DriveLayout.cshtml";
}

<div class="d-flex align-items-center mb-4 mt-2">
    <h4 class="m-0 font-weight-normal text-dark" style="font-size: 1.25rem;">Benimle Paylaşılanlar</h4>
</div>

<div class="section-title text-primary"><i class="fas fa-inbox mr-2"></i> Bana Gönderilenler</div>
<div class="table-responsive mb-5">
    <table class="file-table">
        <thead><tr><th style="width: 45%;">Ad</th><th style="width: 20%;">Paylaşan Kişi</th><th style="width: 20%;">Paylaşım Tarihi</th><th style="width: 15%;">Aksiyon</th></tr></thead>
        <tbody>
            @if (Model.Where(m => m.Owner != "Ben").Any())
            {
                foreach (var file in Model.Where(m => m.Owner != "Ben"))
                {
                    <tr>
                        <td>
                            <a href="/Drive/PreviewFile?id=@file.Id" target="_blank" class="file-name-cell text-decoration-none text-dark">
                                @if (file.Extension == "pdf")
                                {
                                    <i class="fas fa-file-pdf file-icon text-danger"></i>
                                }
                                else if (file.Extension == "xlsx")
                                {

                                    <i class="fas fa-file-excel file-icon text-success"></i>
                                }
                                else
                                {

                                    <i class="fas fa-file file-icon text-secondary"></i>
                                }
                                <span class="text-truncate">@file.Name</span>
                            </a>
                        </td>
                        <td class="text-primary fw-bold">@file.Owner</td>
                        <td class="text-muted">@file.ModifiedDate</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <a href="/Drive/DownloadFile?id=@file.Id" class="btn btn-sm bg-light border text-primary mr-2"><i class="fas fa-download"></i> İndir</a>
                                <form asp-action="UnshareItem" method="post" class="m-0 p-0"><input type="hidden" name="id" value="@file.Id" /><button type="submit" class="btn btn-sm bg-light border text-danger"><i class="fas fa-trash"></i></button></form>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="4" class="text-center py-4 text-muted">Sizinle paylaşılan bir dosya bulunmuyor.</td></tr>
            }
        </tbody>
    </table>
</div>

<div class="section-title text-success"><i class="fas fa-paper-plane mr-2"></i> Benim Paylaştıklarım</div>
<div class="table-responsive">
    <table class="file-table">
        <thead><tr><th style="width: 45%;">Ad</th><th style="width: 20%;">Paylaşılan Kişi</th><th style="width: 20%;">Paylaşım Tarihi</th><th style="width: 15%;">Aksiyon</th></tr></thead>
        <tbody>
            @if (Model.Where(m => m.Owner == "Ben").Any())
            {
                foreach (var file in Model.Where(m => m.Owner == "Ben"))
                {
                    <tr>
                        <td>
                            <a href="/Drive/PreviewFile?id=@file.Id" target="_blank" class="file-name-cell text-decoration-none text-dark">
                                @if (file.Extension == "xlsx")
                                {
                                    <i class="fas fa-file-excel file-icon text-success"></i>
                                }
                                else
                                {

                                    <i class="fas fa-file file-icon text-secondary"></i>
                                }
                                <span class="text-truncate">@file.Name</span>
                            </a>
                        </td>
                        <td class="text-success fw-bold">@file.SharedWith</td>
                        <td class="text-muted">@file.ModifiedDate</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <a href="/Drive/DownloadFile?id=@file.Id" class="btn btn-sm bg-light border text-primary mr-2"><i class="fas fa-download"></i> İndir</a>
                                <form asp-action="UnshareItem" method="post" class="m-0 p-0"><input type="hidden" name="id" value="@file.Id" /><button type="submit" class="btn btn-sm bg-light border text-danger"><i class="fas fa-times"></i> İptal</button></form>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="4" class="text-center py-4 text-muted">Paylaştığınız bir dosya bulunmuyor.</td></tr>
            }
        </tbody>
    </table>
</div>