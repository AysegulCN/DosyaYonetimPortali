@model List<DosyaYonetimPortali.MVC.Models.DriveItemViewModel>
@{
    ViewData["Title"] = "Çöp Kutusu";
    Layout = "~/Views/Shared/_DriveLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4 mt-2">
    <h4 class="font-weight-bold text-dark m-0"><i class="fas fa-trash text-danger mr-2"></i> Çöp Kutusu</h4>
    @if (Model != null && Model.Any())
    {
        <form asp-action="EmptyTrash" asp-controller="Drive" method="post">
            <button type="submit" class="btn btn-outline-danger shadow-sm" style="border-radius: 8px; font-weight: 500;">
                <i class="fas fa-dumpster mr-2"></i> Çöp Kutusunu Boşalt
            </button>
        </form>
    }
</div>

<div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
    <div class="table-responsive bg-white">
        <table class="table table-hover mb-0 align-middle">
            <thead class="bg-light text-muted small">
                <tr>
                    <th class="border-0 px-4 py-3">Ad</th>
                    <th class="border-0 py-3">Silinme Tarihi</th>
                    <th class="border-0 text-right px-4 py-3">Aksiyon</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-4 py-3 font-weight-bold text-dark">
                                <i class="@(item.IsFolder ? "fas fa-folder text-warning" : "fas fa-file-alt text-secondary") mr-3" style="font-size: 20px;"></i>
                                <del>@item.Name</del>
                            </td>
                            <td class="text-muted">@item.ModifiedDate</td>
                            <td class="text-right px-4 py-3">
                                <form asp-action="RestoreFromTrash" asp-controller="Drive" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-light text-success rounded-circle mr-1" title="Geri Yükle"><i class="fas fa-undo"></i></button>
                                </form>
                                <form asp-action="DeletePermanently" asp-controller="Drive" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-light text-danger rounded-circle" title="Kalıcı Olarak Sil"><i class="fas fa-trash-alt"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center py-5 text-muted">
                            <i class="fas fa-trash-restore text-gray-300 mb-3" style="font-size: 40px;"></i>
                            <p class="m-0">Çöp kutunuz şu an tamamen boş.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>