@model List<DosyaYonetimPortali.MVC.Models.DriveItemViewModel>
@{
    ViewData["Title"] = "Çöp Kutusu";
    Layout = "~/Views/Shared/_DriveLayout.cshtml";
}

<style>
    body, #wrapper #content-wrapper { background-color: #fff; }
    .file-table { width: 100%; border-collapse: collapse; }
    .file-table th { color: #5f6368; font-weight: 500; font-size: 13px; text-align: left; padding: 12px 15px; border-bottom: 1px solid #dadce0; }
    .file-table td { padding: 12px 15px; border-bottom: 1px solid #dadce0; color: #3c4043; font-size: 13px; font-weight: 500; vertical-align: middle; cursor: pointer; }
    .file-table tr:hover td { background-color: #f5f5f5; }
    .file-name-cell { display: flex; align-items: center; font-size: 14px; }
    .file-icon { font-size: 20px; margin-right: 15px; width: 24px; text-align: center; }
</style>

<div class="d-flex align-items-center justify-content-between mb-4 mt-2">
    <h4 class="m-0 font-weight-normal text-dark" style="font-size: 1.25rem;">Çöp Kutusu</h4>
    <form asp-action="EmptyTrash" method="post" class="m-0 p-0">
        <button type="submit" class="btn btn-outline-primary" style="border-radius: 20px; font-weight: 500;">
            Çöp Kutusunu Boşalt
        </button>
    </form>
</div>

<div class="alert alert-secondary text-center" style="border-radius: 8px; font-size: 14px; color: #3c4043;">
    <i class="fas fa-info-circle mr-2"></i> Çöp kutusundaki öğeler 30 gün sonra tamamen silinir.
</div>

<div class="table-responsive mt-4">
    <table class="file-table">
        <thead><tr><th style="width: 50%;">Ad</th><th style="width: 25%;">Silinme Tarihi</th><th style="width: 25%;">Aksiyon</th></tr></thead>
        <tbody>
            @if(Model.Any()) {
                foreach (var file in Model)
                {
                    <tr>
                        <td>
                            <div class="file-name-cell">
                                @if (file.Extension == "zip") { <i class="fas fa-file-archive file-icon text-secondary"></i> }
                                else if (file.IsFolder) { <i class="fas fa-folder file-icon text-secondary"></i> }
                                else { <i class="fas fa-file file-icon text-secondary"></i> }
                                <span class="text-truncate">@file.Name</span>
                            </div>
                        </td>
                        <td class="text-muted">@file.ModifiedDate</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <form asp-action="RestoreFromTrash" method="post" class="m-0 p-0 mr-2">
                                    <input type="hidden" name="id" value="@file.Id" />
                                    <button type="submit" class="btn btn-sm btn-light border"><i class="fas fa-undo text-success"></i> Geri Yükle</button>
                                </form>
                                <form asp-action="DeletePermanently" method="post" class="m-0 p-0">
                                    <input type="hidden" name="id" value="@file.Id" />
                                    <button type="submit" class="btn btn-sm btn-light border text-danger"><i class="fas fa-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            } else {
                <tr><td colspan="3" class="text-center py-4 text-muted">Çöp kutusu boş.</td></tr>
            }
        </tbody>
    </table>
</div>